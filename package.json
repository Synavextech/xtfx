{
  "name": "xfx-monorepo",
  "version": "1.0.0",
  "private": true,
  "description": "ExtremeTrader platform - gamified trading system",
  "main": "server/src/server.ts",
  "scripts": {
    "dev:frontend": "vite client --port 3000",
    "dev:backend": "NODE_OPTIONS=\"--experimental-websocket\" nodemon --watch server/src -e ts,json --exec ts-node server/src/server.ts",
    "dev": "concurrently \"npm run dev:frontend\" \"npm run dev:backend\"",
    "build:frontend": "vite build client",
    "build:backend": "tsc -p server/tsconfig.json",
    "build": "npm run build:frontend && npm run build:backend",
    "start": "NODE_OPTIONS=\"--experimental-websocket\" ts-node server/src/server.ts"
  },
  "dependencies": {
    "@fastify/cookie": "^11.0.2",
    "@fastify/cors": "^10.1.0",
    "@fastify/static": "^8.3.0",
    "@fastify/websocket": "^11.2.0",
    "@supabase/supabase-js": "^2.43.4",
    "axios": "^1.7.2",
    "bcryptjs": "^2.4.3",
    "canvas-confetti": "^1.9.3",
    "dotenv": "^16.4.5",
    "fastify": "^5.9.0",
    "ioredis": "^5.4.1",
    "jsonwebtoken": "^9.0.2",
    "lightweight-charts": "^4.1.3",
    "lucide-react": "^0.379.0",
    "nodemailer": "^9.0.3",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-router-dom": "^6.23.1",
    "stripe": "^15.12.0",
    "uWebSockets.js": "github:uNetworking/uWebSockets.js#v20.68.0",
    "ws": "^8.17.0",
    "zustand": "^4.5.2"
  },
  "devDependencies": {
    "@types/bcryptjs": "^2.4.6",
    "@types/canvas-confetti": "^1.6.4",
    "@types/jsonwebtoken": "^9.0.6",
    "@types/node": "^20.14.2",
    "@types/nodemailer": "^6.4.15",
    "@types/react": "^18.3.3",
    "@types/react-dom": "^18.3.0",
    "@types/ws": "^8.5.10",
    "@vitejs/plugin-react": "^5.2.0",
    "autoprefixer": "^10.4.19",
    "concurrently": "^8.2.2",
    "nodemon": "^3.1.2",
    "postcss": "^8.4.38",
    "tailwindcss": "^3.4.3",
    "ts-node": "^10.9.2",
    "typescript": "^5.4.5",
    "vite": "^8.1.3"
  }
}
